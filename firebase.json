{
  "hosting": {
    "public": "",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/contact",
        "function": "sendContactEmail"
      },
      {
        "source": "/party/**",
        "destination": "/party/index.html"
      }
    ]
  }
}